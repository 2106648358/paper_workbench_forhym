  "indicator_definitions": {
    "popularity": "流行度 - 收视率、参与人数、社交媒体讨论度综合评分",
    "gender_equity": "性别平等 - 男女参赛比例均衡度",
    "sustainability": "可持续性 - 碳排放、场馆成本等综合评分（越高越可持续）",
    "inclusivity": "包容性 - 残奥关联、发展中国家参与度",
    "innovation": "创新性 - 年轻化程度、技术革新、新近加入程度",
    "safety": "安全性 - 受伤率反向评分（越高越安全）"
  },
  "data_sources": {
    "popularity": ["IOC Reports", "Nielsen", "Social Media APIs"],
    "gender_equity": ["IOC Official Reports", "Historical Data"],
    "sustainability": ["IOC Sustainability Reports", "Academic Literature"],
    "inclusivity": ["IPC Reports", "Participating Nations Statistics"],
    "innovation": ["Olympedia", "IFs Reports"],
    "safety": ["IOC Medical Reports", "Academic Literature"]
  }
